arrows(c(0.9, 1.9, 2.9, 3.9, 4.9), props1$low, c(0.9, 1.9, 2.9, 3.9, 4.9), props1$high, length=0.05, angle=90, code=3, xlab = "")
arrows(c(1, 2, 3, 4, 5), props2$low, c(1, 2, 3, 4, 5), props2$high, length=0.05, angle=90, code=3, xlab = "", col = "red")
arrows(c(1.1, 2.1, 3.1, 4.1, 5.1), props3$low, c(1.1, 2.1, 3.1, 4.1, 5.1), props3$high, length=0.05, angle=90, code=3, xlab = "", col="blue")
axis(side = 1, labels = FALSE)
text(x=c(0.8, 1.8, 2.8, 3.8, 4.8), y = par("usr")[3]-0.15,
srt = 60, adj = 0.1, xpd = NA, labels = c("< 1965", "1965 - 1980","1980 - 1995","1995 - 2010","> 2010"))
legend(x = "topleft",          # Position
legend = c("Threshold = 5", "Threshold = 10", "Threshold = 20"),  # Legend texts
fill = c("black", "red", "blue"),
border = c("black", "red", "blue"),
cex = 0.9,
box.lwd = 0,
bty = "n"
)
